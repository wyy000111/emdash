{
	"name": "@emdash-cms/auth-atproto",
	"version": "0.2.18",
	"description": "AT Protocol / Atmosphere authentication provider for EmDash CMS",
	"type": "module",
	"main": "src/auth.ts",
	"exports": {
		".": "./src/auth.ts",
		"./admin": "./src/admin.tsx",
		"./oauth-client": "./src/oauth-client.ts",
		"./resolve-handle": "./src/resolve-handle.ts",
		"./routes/*": "./src/routes/*"
	},
	"files": [
		"src"
	],
	"keywords": [
		"emdash",
		"cms",
		"auth",
		"atproto",
		"bluesky",
		"atmosphere"
	],
	"author": "Matt Kane",
	"license": "MIT",
	"peerDependencies": {
		"astro": ">=5",
		"emdash": "workspace:>=0.15.0",
		"react": ">=18"
	},
	"devDependencies": {
		"@atcute/lexicons": "catalog:",
		"@cloudflare/kumo": "catalog:",
		"@types/react": "^19.0.0",
		"vitest": "catalog:"
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsgo --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/auth-atproto"
	},
	"dependencies": {
		"@atcute/identity-resolver": "catalog:",
		"@atcute/oauth-node-client": "catalog:",
		"@emdash-cms/auth": "workspace:*",
		"kysely": "catalog:"
	}
}
